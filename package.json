{
  "name": "linecut",
  "private": true,
  "version": "0.2.0-alpha.5",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "npm run check:errors && tsc && vite build",
    "check:errors": "node scripts/check-error-boundaries.mjs",
    "format": "prettier --write . && npm run format:rust",
    "format:check": "prettier --check . && npm run format:rust:check",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "preview": "vite preview --host 127.0.0.1 --port 1421",
    "release:build": "node scripts/release.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.4",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
