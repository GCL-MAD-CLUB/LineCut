{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LineCut",
  "version": "0.2.0-alpha.2",
  "identifier": "com.linecut.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": " LineCut",
        "width": 1320,
        "height": 860,
        "maximized": true,
        "minWidth": 1080,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": ["icons/icon.ico"],
    "fileAssociations": [
      {
        "ext": ["lcp"],
        "name": "LineCut.Project",
        "description": "LineCut Project",
        "role": "Editor"
      }
    ],
    "externalBin": ["bin/ffmpeg", "bin/ffprobe"],
    "resources": ["../LICENSE", "../THIRD_PARTY_NOTICES.md"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/ffmpeg-options.nsh",
        "template": "./windows/installer.nsi",
        "languages": ["SimpChinese"]
      }
    }
  }
}
